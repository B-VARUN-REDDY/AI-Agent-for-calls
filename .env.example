# Copy to `.env` and fill in. Never commit the real .env.

# --- Twilio (telephony) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# The SINGLE number you use for ALL test calls, E.164. Submit this on the form.
TWILIO_CALLER_NUMBER=+1XXXXXXXXXX

# Public host Twilio can reach (your ngrok host, NO scheme, NO trailing slash)
PUBLIC_HOST=your-subdomain.ngrok-free.app

# --- Speech-to-text ---
DEEPGRAM_API_KEY=your_deepgram_key

# --- LLMs (patient persona + bug analysis) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Text-to-speech ---
# Both providers are built in. Switch by setting TTS_PROVIDER to cartesia or elevenlabs.
TTS_PROVIDER=cartesia

CARTESIA_API_KEY=your_cartesia_key
CARTESIA_VOICE_ID=your_chosen_voice_id
CARTESIA_MODEL=sonic-2

# Only needed if TTS_PROVIDER=elevenlabs (use a Flash/Turbo model to stay cheap)
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=your_chosen_voice_id
ELEVENLABS_MODEL=eleven_flash_v2_5

# --- Optional tuning ---
MAX_CALL_SECONDS=240
PATIENT_LLM_MODEL=claude-sonnet-4-6
ANALYSIS_LLM_MODEL=claude-opus-4-8
